{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code.org/schemas/state-gap-data.schema.json",
  "title": "Interactive Gap Analysis Map Data",
  "description": "Structured data contract for the interactive state gap analysis map.",
  "type": "object",
  "additionalProperties": false,
  "required": ["tiers", "states"],
  "properties": {
    "tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "states": {
      "type": "array",
      "minItems": 51,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "code",
          "name",
          "tier",
          "accessPercent",
          "participationPercent",
          "displayRegion"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "code": {
            "type": "string",
            "pattern": "^[A-Z]{2}$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "tier": {
            "type": "string",
            "minLength": 1
          },
          "accessPercent": {
            "type": "number"
          },
          "participationPercent": {
            "type": "number"
          },
          "dataStatus": {
            "type": "string",
            "enum": ["complete", "unavailable"],
            "default": "complete"
          },
          "reportUrl": {
            "type": "string",
            "format": "uri"
          },
          "presentationUrl": {
            "type": "string",
            "format": "uri"
          },
          "displayRegion": {
            "type": "string",
            "enum": ["contiguous", "alaskaInset", "hawaiiInset"]
          },
          "isSelectable": {
            "type": "boolean",
            "default": true
          }
        }
      }
    }
  }
}
