#####################################
# Application Environment Variables #
#####################################

# The secret token to use for the Contentful webhook to notify that a particular page should be updated.
CONTENTFUL_REVALIDATE_TOKEN=

# The secret token to enable Next.js draft mode (bypass cache)
DRAFT_MODE_TOKEN=

# The stage the application will run as
# One of: development (default), pr, test, production
NEXT_PUBLIC_STAGE=development

# In production mode, the redis cache is used to store Next.js full router page caches and fetch responses
# REDIS_URL=redis://localhost:6379

####################################
# Contentful Environment Variables #
####################################

# For values, see: https://www.contentful.com/developers/docs/references/authentication/

# Contentful Space ID
# Viewable in the Contentful web app under Settings > API keys
# See: https://contentful.github.io/contentful.js/contentful/latest/interfaces/CreateClientParams.html#space
CONTENTFUL_SPACE_ID=

# Contentful Environment ID
# The Contentful environment id to use. This is the environment that will be used to fetch content.
# Valid options are: development, test, and production.
# Normally, you would use the development environment for development and testing, and the production environment for production.
# Note: Production must only use the production environment
# See: https://contentful.github.io/contentful.js/contentful/latest/interfaces/CreateClientParams.html#environment
CONTENTFUL_ENV_ID=development

# The Contentful delivery token which only allows viewing published content.
# Viewable in the Contentful web app under Settings > API keys
# See: https://contentful.github.io/contentful.js/contentful/latest/interfaces/CreateClientParams.html#accessToken
CONTENTFUL_DELIVERY_TOKEN=

# The Contentful preview token which only allows viewing published and unpublished content.
# Viewable in the Contentful web app under Settings > API keys
# See: https://contentful.github.io/contentful.js/contentful/latest/interfaces/CreateClientParams.html#accessToken
CONTENTFUL_PREVIEW_TOKEN=

# The Contentful content type id for experience content
# Viewable in the Contentful web app under Settings > Experiences > API Identifier
CONTENTFUL_EXPERIENCE_CONTENT_TYPE_ID=

#################################
# Statsig Environment Variables #
#################################

# The client API key for statsig
# Viewable in AWS Secrets Manager under key `development/cdo/statsig_marketing_api_client_key`
# See: https://docs.statsig.com/sdk-keys/api-keys/
STATSIG_CLIENT_KEY=

#################################
# Sentry Environment Variables  #
#################################

# Sentry DSN — one value per environment (dev/test/production each have their own Sentry project).
# The DSN is a public identifier, safe to expose in the browser bundle; it can only send events, not read data.
# Used by the browser SDK (src/providers/sentry/SentryLoader.tsx) and the server SDK (src/sentry.server.config.ts).
# Browser and server SDKs are a no-op when getStage() does not resolve to test or production.
NEXT_PUBLIC_SENTRY_DSN=

# Git SHA of the build. Tagged onto Sentry events via `release` so the UI can group/track per-deploy. Supplied
# by CI via the GIT_SHA Docker build-arg (see .github/workflows/marketing-app-deploy.yml). Empty locally is fine.
NEXT_PUBLIC_SENTRY_RELEASE=

############################################
# OpenTelemetry Environment Variables      #
# Disabled by default, uncomment to enable #
############################################

# Whether to enable instrumentation for both the backend and frontend
# NEXT_PUBLIC_INSTRUMENTATION_ENABLED=false

# Sentry OTLP traces ingest endpoint.
# Format: https://<org_id>.ingest.us.sentry.io/api/<project_id>/integration/otlp/v1/traces
#OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=

# Sentry OTLP auth header (derived from DSN public key).
# Format: x-sentry-auth=sentry sentry_key=<public_key>
#OTEL_EXPORTER_OTLP_TRACES_HEADERS=

# Sampling — standard OTel env vars. If unset, NodeSDK defaults to `parentbased_always_on` (100%), which is useful
# for local development. Production deploys set this to parentbased_traceidratio with a 0.01 arg (1%).
# See: https://opentelemetry.io/docs/specs/otel/configuration/sdk-environment-variables/
#OTEL_TRACES_SAMPLER=parentbased_traceidratio
#OTEL_TRACES_SAMPLER_ARG=0.01

# The following environment variables are used to configure OpenTelemetry for the application.
# These default variables do not need to be changed unless you are using a different OpenTelemetry setup.
#OTEL_SERVICE_NAME=marketing-sites
#OTEL_ATTRIBUTE_VALUE_LENGTH_LIMIT=4095
#OTEL_EXPORTER_OTLP_COMPRESSION=gzip
#OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
